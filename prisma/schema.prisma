generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model cache {
  key        String @id @db.VarChar(255)
  value      String @db.MediumText
  expiration Int
}

model cache_locks {
  key        String @id @db.VarChar(255)
  owner      String @db.VarChar(255)
  expiration Int
}

model failed_jobs {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  uuid       String   @unique(map: "failed_jobs_uuid_unique") @db.VarChar(255)
  connection String   @db.Text
  queue      String   @db.Text
  payload    String   @db.LongText
  exception  String   @db.LongText
  failed_at  DateTime @default(now()) @db.Timestamp(0)
}

model job_batches {
  id             String  @id @db.VarChar(255)
  name           String  @db.VarChar(255)
  total_jobs     Int
  pending_jobs   Int
  failed_jobs    Int
  failed_job_ids String  @db.LongText
  options        String? @db.MediumText
  cancelled_at   Int?
  created_at     Int
  finished_at    Int?
}

model jobs {
  id           BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  queue        String @db.VarChar(255)
  payload      String @db.LongText
  attempts     Int    @db.UnsignedTinyInt
  reserved_at  Int?   @db.UnsignedInt
  available_at Int    @db.UnsignedInt
  created_at   Int    @db.UnsignedInt

  @@index([queue], map: "jobs_queue_index")
}

model migrations {
  id        Int    @id @default(autoincrement()) @db.UnsignedInt
  migration String @db.VarChar(255)
  batch     Int
}

model password_reset_tokens {
  email      String    @id @db.VarChar(255)
  token      String    @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
}

model service_form_fields {
  id                        BigInt                      @id @default(autoincrement()) @db.UnsignedBigInt
  service_id                BigInt                      @db.UnsignedBigInt
  label                     String                      @db.VarChar(255)
  name                      String                      @db.VarChar(255)
  type                      String                      @db.VarChar(255)
  is_required               Boolean                     @default(false)
  options                   String?                     @db.LongText
  placeholder               String?                     @db.VarChar(255)
  help_text                 String?                     @db.VarChar(255)
  order                     Int                         @default(0) @db.UnsignedInt
  meta                      String?                     @db.LongText
  created_at                DateTime?                   @db.Timestamp(0)
  updated_at                DateTime?                   @db.Timestamp(0)
  services                  services                    @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "service_form_fields_service_id_foreign")
  service_submission_values service_submission_values[]

  @@unique([service_id, name], map: "service_form_fields_service_id_name_unique")
}

model service_submission_members {
  id                  BigInt                          @id @default(autoincrement()) @db.UnsignedBigInt
  submission_id       BigInt                          @db.UnsignedBigInt
  user_id             BigInt                          @db.UnsignedBigInt
  role                service_submission_members_role @default(member)
  created_at          DateTime?                       @default(now()) @db.Timestamp(0)
  updated_at          DateTime?                       @default(now()) @db.Timestamp(0)
  service_submissions service_submissions             @relation(fields: [submission_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_submission_member_submission")
  users               users                           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_submission_member_user")

  @@unique([submission_id, user_id], map: "uq_submission_user")
  @@index([user_id], map: "fk_submission_member_user")
}

model service_submission_values {
  id                  BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  submission_id       BigInt              @db.UnsignedBigInt
  field_id            BigInt              @db.UnsignedBigInt
  value               String?             @db.Text
  file_path           String?             @db.VarChar(255)
  created_at          DateTime?           @db.Timestamp(0)
  updated_at          DateTime?           @db.Timestamp(0)
  service_form_fields service_form_fields @relation(fields: [field_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "service_submission_values_field_id_foreign")
  service_submissions service_submissions @relation(fields: [submission_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "service_submission_values_submission_id_foreign")

  @@index([field_id], map: "service_submission_values_field_id_foreign")
  @@index([submission_id, field_id], map: "service_submission_values_submission_id_field_id_index")
}

model service_submissions {
  id                         BigInt                       @id @default(autoincrement()) @db.UnsignedBigInt
  service_id                 BigInt                       @db.UnsignedBigInt
  applicant_name             String?                      @db.VarChar(255)
  applicant_email            String?                      @db.VarChar(255)
  status                     String                       @default("submitted") @db.VarChar(32)
  assigned_to                BigInt?                      @db.UnsignedBigInt
  is_priority                Boolean                      @default(false)
  tracking_code              String                       @unique(map: "tracking_code") @db.VarChar(50)
  created_at                 DateTime?                    @db.Timestamp(0)
  updated_at                 DateTime?                    @db.Timestamp(0)
  service_submission_members service_submission_members[]
  service_submission_values  service_submission_values[]
  users                      users?                       @relation(fields: [assigned_to], references: [id], onUpdate: Restrict, map: "fk_service_submissions_assigned_to")
  services                   services                     @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "service_submissions_service_id_foreign")
  submission_notes           submission_notes[]
  submission_team_members    submission_team_members[]

  @@index([assigned_to], map: "fk_service_submissions_assigned_to")
  @@index([service_id], map: "service_submissions_service_id_foreign")
}

model services {
  id                  BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  order               Int                   @default(0)
  name                String                @db.VarChar(255)
  icon                String?               @db.VarChar(255)
  requirements        String?               @db.LongText
  created_at          DateTime?             @db.Timestamp(0)
  updated_at          DateTime?             @db.Timestamp(0)
  service_form_fields service_form_fields[]
  service_submissions service_submissions[]
}

model sessions {
  id            String  @id @db.VarChar(255)
  user_id       BigInt? @db.UnsignedBigInt
  ip_address    String? @db.VarChar(45)
  user_agent    String? @db.Text
  payload       String  @db.LongText
  last_activity Int

  @@index([last_activity], map: "sessions_last_activity_index")
  @@index([user_id], map: "sessions_user_id_index")
}

model submission_notes {
  id                  BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  submission_id       BigInt              @db.UnsignedBigInt
  user_id             BigInt?             @db.UnsignedBigInt
  status_from         String?             @db.VarChar(32)
  status_to           String?             @db.VarChar(32)
  note                String?             @db.Text
  created_at          DateTime?           @db.Timestamp(0)
  updated_at          DateTime?           @db.Timestamp(0)
  file_path           String?             @db.VarChar(255)
  service_submissions service_submissions @relation(fields: [submission_id], references: [id], onDelete: Cascade, map: "submission_notes_submission_id_foreign")
  users               users?              @relation(fields: [user_id], references: [id], map: "submission_notes_user_id_foreign")

  @@index([submission_id, created_at], map: "submission_notes_submission_id_created_at_index")
  @@index([user_id], map: "submission_notes_user_id_foreign")
}

model submission_team_members {
  id                  BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  submission_id       BigInt              @db.UnsignedBigInt
  user_id             BigInt              @db.UnsignedBigInt
  created_at          DateTime?           @db.Timestamp(0)
  updated_at          DateTime?           @db.Timestamp(0)
  service_submissions service_submissions @relation(fields: [submission_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "submission_team_members_submission_id_foreign")
  users               users               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "submission_team_members_user_id_foreign")

  @@unique([submission_id, user_id], map: "submission_team_members_submission_id_user_id_unique")
  @@index([user_id], map: "submission_team_members_user_id_foreign")
}

model users {
  id                         BigInt                       @id @default(autoincrement()) @db.UnsignedBigInt
  name                       String                       @db.VarChar(255)
  username                   String?                      @unique(map: "users_username_unique") @db.VarChar(50)
  phone                      String?                      @db.VarChar(30)
  email                      String                       @unique(map: "users_email_unique") @db.VarChar(255)
  email_verified_at          DateTime?                    @db.Timestamp(0)
  password                   String                       @db.VarChar(255)
  remember_token             String?                      @db.VarChar(100)
  created_at                 DateTime?                    @db.Timestamp(0)
  updated_at                 DateTime?                    @db.Timestamp(0)
  notifications              notifications[]
  service_submission_members service_submission_members[]
  service_submissions        service_submissions[]
  submission_notes           submission_notes[]
  submission_team_members    submission_team_members[]
  user_roles                 user_roles[]
}

model permissions {
  id               BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  name             String             @unique(map: "name") @db.VarChar(50)
  description      String?            @db.VarChar(255)
  role_permissions role_permissions[]
}

model role_permissions {
  role_id       BigInt      @db.UnsignedBigInt
  permission_id BigInt      @db.UnsignedBigInt
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_rp_permission")
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_rp_role")

  @@id([role_id, permission_id])
  @@index([permission_id], map: "fk_rp_permission")
}

model roles {
  id               BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  name             String             @unique(map: "name") @db.VarChar(50)
  description      String?            @db.VarChar(255)
  role_permissions role_permissions[]
  user_roles       user_roles[]
}

model user_roles {
  user_id BigInt @db.UnsignedBigInt
  role_id BigInt @db.UnsignedBigInt
  roles   roles  @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_ur_role")
  users   users  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_ur_user")

  @@id([user_id, role_id])
  @@index([role_id], map: "fk_ur_role")
}

model notifications {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    BigInt    @db.UnsignedBigInt
  title      String    @db.VarChar(255)
  message    String    @db.Text
  type       String    @default("info") @db.VarChar(32)
  link       String?   @db.VarChar(255)
  is_read    Boolean   @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(0)
  updated_at DateTime? @default(now()) @db.Timestamp(0)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "notifications_user_id_foreign")

  @@index([user_id, is_read], map: "notifications_user_id_is_read_index")
}

enum service_submission_members_role {
  member
}
